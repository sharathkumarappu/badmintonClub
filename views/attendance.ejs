<!DOCTYPE html>
<html>

<head>
	<title> Indian Badminton Club Arnhem </title>
	<%- include ('head') %>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
</head>

<body>

	<%- include ('navbar') %>
	<% if (savedCount !== null) { %>
		<div class="alert alert-success attendance-toast" role="alert" id="attendanceSavedAlert">
			Attendance saved for <strong><%= savedCount %></strong> member<%= savedCount === 1 ? '' : 's' %>.
		</div>
	<% } %>

		<div class="container">
			<div class="row">
				<div class="col-sm-12">
					<h1>Attendance</h1>
				</div>
				<div class="col-sm-12 text-center section-spacing">
					<button type="button" class="btn btn-primary home-action-btn" data-toggle="modal" data-target="#markAttendanceModal">
						Mark Attendance
					</button>
				</div>
			</div>

			<!-- Mark Attendance Modal -->
			<div class="modal fade" id="markAttendanceModal" tabindex="-1" role="dialog" aria-labelledby="markAttendanceModalLabel">
				<div class="modal-dialog" role="document">
					<div class="modal-content">
						<div class="modal-header">
							<button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
							<h4 class="modal-title" id="markAttendanceModalLabel">Mark Attendance</h4>
						</div>
						<div class="modal-body">
							<div class="form-group">
								<label for="attendanceDate">Select Date</label>
								<input type="date" id="attendanceDate" class="form-control" />
							</div>
							<form method="POST" action="/attendance" id="attendanceForm">
								<input type="hidden" name="selectedDate" id="selectedDate" />
								<div id="attendanceFormWrapper" style="display: none;">
									<div class="attendance-toolbar">
										<input type="text" id="memberFilter" class="form-control" placeholder="Filter members..." />
										<button type="button" id="selectVisible" class="btn btn-default">Select Visible</button>
										<button type="button" id="clearVisible" class="btn btn-default">Clear Visible</button>
									</div>
									<div id="attendanceMemberList" class="attendance-list">
										<% parsedData.forEach((member) => { %>
											<div class="attendance-row" data-member-name="<%= member.name.toLowerCase() %>">
												<span class="attendance-name"><%= member.name %></span>
												<div class="attendance-choice">
													<label for="attendance-<%= member.id %>">Present</label>
													<input type="checkbox" id="attendance-<%= member.id %>" name="attendance[<%= member.id %>]" value="present" class="attendance-radio" data-attendance-dates="<%= Array.isArray(member.attendance) ? member.attendance.join('|') : '' %>" />
												</div>
											</div>
										<% }) %>
									</div>
									<div class="attendance-submit-wrap">
										<button type="submit" id="attendanceSubmit">Submit</button>
									</div>
								</div>
							</form>
						</div>
					</div>
				</div>
			</div>

			<div class="row presence-section">
				<div class="col-sm-12">
					<h4>Check Presence</h4>
					<div class="form-group">
						<input type="text" id="presenceDateRange" class="form-control" placeholder="Select a date range..." readonly />
					</div>
					<button type="button" id="presenceGoBtn" class="btn btn-primary" disabled>Go</button>
				</div>
			</div>

			<div class="row" id="presenceResultWrapper" style="display:none; margin-top: 20px;">
				<div class="col-sm-12">
					<p id="presenceRangeLabel" class="text-muted"></p>
					<table class="table table-striped table-bordered">
						<thead><tr><th>Member Name</th><th>Present Days</th></tr></thead>
						<tbody id="presenceTableBody"></tbody>
					</table>
				</div>
			</div>
		</div>

		<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
		<script>
			const attendanceDateInput = document.getElementById("attendanceDate");
			const attendanceFormWrapper = document.getElementById("attendanceFormWrapper");
			const selectedDateInput = document.getElementById("selectedDate");
			const attendanceSubmit = document.getElementById("attendanceSubmit");
			const attendanceRadios = Array.from(document.querySelectorAll(".attendance-radio"));
			const memberFilterInput = document.getElementById("memberFilter");
			const selectVisibleButton = document.getElementById("selectVisible");
			const clearVisibleButton = document.getElementById("clearVisible");
			const attendanceRows = Array.from(document.querySelectorAll(".attendance-row"));

			const updateSubmitState = () => {
				attendanceSubmit.disabled = false;
			};

			const applyMemberFilter = () => {
				const query = (memberFilterInput.value || "").toLowerCase().trim();
				attendanceRows.forEach((row) => {
					const memberName = row.dataset.memberName || "";
					row.style.display = memberName.includes(query) ? "flex" : "none";
				});
			};

			attendanceDateInput.addEventListener("change", () => {
				if (!attendanceDateInput.value) {
					attendanceFormWrapper.style.display = "none";
					selectedDateInput.value = "";
					memberFilterInput.value = "";
					attendanceRadios.forEach((radio) => {
						radio.checked = false;
					});
					applyMemberFilter();
					updateSubmitState();
					return;
				}

				selectedDateInput.value = attendanceDateInput.value;
				attendanceFormWrapper.style.display = "block";
				attendanceRadios.forEach((radio) => {
					const recordedDates = (radio.dataset.attendanceDates || "")
						.split("|")
						.filter((date) => date);
					radio.checked = recordedDates.includes(attendanceDateInput.value);
				});
				applyMemberFilter();
				updateSubmitState();
			});

			attendanceRadios.forEach((radio) => {
				radio.addEventListener("change", updateSubmitState);
			});

			memberFilterInput.addEventListener("input", applyMemberFilter);

			selectVisibleButton.addEventListener("click", () => {
				attendanceRows.forEach((row) => {
					if (row.style.display !== "none") {
						const radio = row.querySelector(".attendance-radio");
						radio.checked = true;
					}
				});
				updateSubmitState();
			});

			clearVisibleButton.addEventListener("click", () => {
				attendanceRows.forEach((row) => {
					if (row.style.display !== "none") {
						const radio = row.querySelector(".attendance-radio");
						radio.checked = false;
					}
				});
				updateSubmitState();
			});

			// Embed member attendance data for client-side range query
			const membersData = <%- JSON.stringify(parsedData.map(m => ({ name: m.name, attendance: Array.isArray(m.attendance) ? m.attendance : [] }))) %>;

			// Compute months: current-2, current-1, current
			const today = new Date();
			const twoMonthsAgo = new Date(today.getFullYear(), today.getMonth() - 2, 1);

			let presenceRange = { from: null, to: null };
			const presenceGoBtn = document.getElementById("presenceGoBtn");
			const presenceResultWrapper = document.getElementById("presenceResultWrapper");
			const presenceTableBody = document.getElementById("presenceTableBody");
			const presenceRangeLabel = document.getElementById("presenceRangeLabel");

			const presencePicker = flatpickr("#presenceDateRange", {
				mode: "range",
				showMonths: 3,
				dateFormat: "Y-m-d",
				onChange: function(selectedDates) {
					if (selectedDates.length === 2) {
						presenceRange.from = selectedDates[0];
						presenceRange.to = selectedDates[1];
						presenceGoBtn.disabled = false;
					} else {
						presenceRange.from = null;
						presenceRange.to = null;
						presenceGoBtn.disabled = true;
					}
				}
			});
			presencePicker.jumpToDate(twoMonthsAgo);

			presenceGoBtn.addEventListener("click", () => {
				const { from, to } = presenceRange;
				if (!from || !to) return;

				const results = membersData.map((member) => {
					const count = member.attendance.filter((dateStr) => {
						const d = new Date(dateStr);
						return d >= from && d <= to;
					}).length;
					return { name: member.name, count };
				}).sort((a, b) => b.count - a.count);

				const fmt = (d) => d.toISOString().slice(0, 10);
				presenceRangeLabel.textContent = `Showing attendance from ${fmt(from)} to ${fmt(to)}`;

				presenceTableBody.innerHTML = results.map((r) =>
					`<tr><td>${r.name}</td><td>${r.count}</td></tr>`
				).join("");

				presenceResultWrapper.style.display = "block";
			});

			const attendanceSavedAlert = document.getElementById("attendanceSavedAlert");
			if (attendanceSavedAlert) {
				setTimeout(() => {
					attendanceSavedAlert.style.transition = "opacity 0.4s ease";
					attendanceSavedAlert.style.opacity = "0";
					setTimeout(() => {
						attendanceSavedAlert.remove();
					}, 400);
				}, 3500);
			}
		</script>
</body>

</html>
