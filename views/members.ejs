<!DOCTYPE html>
<html>

<head>
	<title> Indian Badminton Club Arnhem </title>
	<%- include ('head') %>
</head>

<body>

	<%- include ('navbar') %>

		<div class="container">
			<div class="row">
				<div class="col-sm-12">
					<h1>Members</h1>
				</div>
				<div id="membersGrid" class="col-sm-12">
					<% parsedData.forEach((member)=>{ %>
						<div class="col-md-3 col-sm-4 poster text-center">

							<a href="/member/<%= member.id %>">
								<img src="/icons/profile_pic.png"
									class="img-responsive" />
								<p class="overview-header">
									<%= member.name %>
								</p>
							</a>
							<p class="overview">
								<%= member.team %>
							</p>
						</div>
						<% }) %>

				</div>
				<div class="section">
					<form action="/member-registration" method="GET">
						<button type="submit" class="btn btn-primary button-form">Register New Member</button>
					</form>
				</div>
			</div>
		</div>
</body>

</html>
